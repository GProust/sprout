# Copy this file to `keystore.properties` (which is git-ignored) and fill in
# your real values to sign release builds locally. See docs/RELEASING.md §2.
#
# In CI, set these instead as environment variables:
#   SPROUT_KEYSTORE_FILE, SPROUT_KEYSTORE_PASSWORD, SPROUT_KEY_ALIAS, SPROUT_KEY_PASSWORD

storeFile=/absolute/path/to/sprout-upload.jks
storePassword=changeme
keyAlias=sprout
keyPassword=changeme
